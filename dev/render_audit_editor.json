{
  "roots": [
    "cpp/infernux/function/renderer",
    "python/Infernux/renderstack"
  ],
  "extensions": [
    ".cpp",
    ".h",
    ".py",
    ".pyi"
  ],
  "exclude_globs": [
    "external/**",
    "**/__pycache__/**"
  ],
  "duplicate_exclude_globs": [
    "python/Infernux/renderstack/__init__.py",
    "python/Infernux/renderstack/**/*.pyi"
  ],
  "owned_string_literal_paths": [
    "python/Infernux/renderstack/_pipeline_common.py",
    "python/Infernux/renderstack/_pipeline_common.pyi"
  ],
  "monitored_string_literals": [
    "color",
    "depth",
    "shadow_map",
    "gbuffer_albedo",
    "gbuffer_normal",
    "gbuffer_material",
    "gbuffer_emission",
    "after_opaque",
    "after_sky",
    "after_transparent",
    "before_post_process",
    "after_post_process",
    "fullscreen_blit",
    "_ComponentGizmos",
    "_EditorGizmos",
    "_EditorTools",
    "outline_mask",
    "outline_composite"
  ],
  "watch_numeric_literals": [
    "14",
    "16",
    "32",
    "64",
    "128",
    "256",
    "1024",
    "2500",
    "2999",
    "5000",
    "32500",
    "32700"
  ],
  "ignore_numeric_literals": [
    "0",
    "1",
    "2",
    "3",
    "4",
    "0u",
    "1u",
    "2u",
    "3u",
    "4u",
    "0.0",
    "1.0",
    "2.0",
    "0.0f",
    "1.0f",
    "2.0f"
  ],
  "duplicate_window_size": 6,
  "duplicate_min_occurrences": 2,
  "numeric_min_occurrences": 3,
  "top_duplicates": 15,
  "top_hotspots": 12,
  "report_title": "Editor Render Audit Report",
  "include_globs": [
    "cpp/infernux/function/renderer/OutlineRenderer.cpp",
    "cpp/infernux/function/renderer/SceneRenderGraph.cpp",
    "cpp/infernux/function/renderer/gui/**",
    "cpp/infernux/function/renderer/VkCoreDraw.cpp",
    "cpp/infernux/function/renderer/VkCoreGlobals.cpp",
    "cpp/infernux/function/renderer/VkCoreMaterial.cpp"
  ]
}
